# VBScript ASP Server 配置文件示例
# 复制此文件为 .env 并根据需要修改配置

# 是否显示目录列表 (true/false)
DIRECTORY_LISTING=false

# Web 根目录路径
HOME_DIR=./www

# 默认索引文件
INDEX_FILE=index.asp

# 服务端口号
PORT=8080

# 是否支持父路径访问 (../) (true/false)
# 警告：启用此选项可能存在安全风险
ALLOW_PARENT_PATH=false

# 是否启用调试模式 (true/false)
DEBUG=false

# 是否显示详细错误信息 (true/false)
# 生产环境建议关闭
DETAILED_ERROR=false

# 自定义错误页面（相对于 home_dir）
# ERROR_PAGE=error.html

# ASP 文件扩展名（逗号分隔）
ASP_EXT=asp,asa

# Runtime 目录路径（用于 Session、缓存等硬盘存储）
# 默认为 ./runtime
RUNTIME_DIR=./runtime

# 日期时间格式配置
# 支持的占位符：YYYY, YY, MM, DD, HH, MM, SS
# 默认格式与 Windows IIS 保持一致
NOW_FORMAT=YYYY/MM/DD HH:MM:SS
DATE_FORMAT=YYYY/MM/DD
TIME_FORMAT=HH:MM:SS

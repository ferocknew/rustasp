# =============================================================================
# VBScript ASP Server 配置文件示例
# 复制此文件为 .env 并根据需要修改配置
# =============================================================================

# =============================================================================
# 基础 HTTP 服务配置
# =============================================================================

# 绑定地址（默认 0.0.0.0，支持 Docker 容器访问）
# 本地开发可设置为 127.0.0.1
HOST=0.0.0.0

# 是否显示目录列表 (true/false)
# 当访问目录且没有索引文件时，是否显示文件列表
DIRECTORY_LISTING=false

# Web 根目录路径
# 所有 ASP 文件和静态资源都从此目录提供
HOME_DIR=./www

# 默认索引文件（支持多个，逗号分隔）
# 访问目录时会按顺序查找这些文件
INDEX_FILE=index.asp,index.html

# 索引文件功能开关 (true/false)
# 设置为 false 时禁用自动索引文件查找
INDEX_FILE_ENABLE=true

# 服务端口号
PORT=8080

# 是否支持父路径访问 (../) (true/false)
# 警告：启用此选项可能存在安全风险，允许访问 HOME_DIR 之外的文件
ALLOW_PARENT_PATH=false

# ASP 文件扩展名（逗号分隔）
# 只有这些扩展名的文件会被当作 ASP 脚本执行
ASP_EXT=asp,asa

# =============================================================================
# 调试与错误处理配置
# =============================================================================

# 是否启用调试模式 (true/false)
# 开启后会输出详细的解析和执行日志
DEBUG=false

# 是否显示详细错误信息 (true/false)
# 生产环境建议关闭，避免泄露敏感信息
DETAILED_ERROR=false

# 自定义错误页面（相对于 home_dir）
# 当发生错误时显示此页面，不设置则使用默认错误页面
# ERROR_PAGE=error.html

# =============================================================================
# Session 会话管理配置
# =============================================================================

# Session 存储模式 (memory/json/redis)
#   memory - 纯内存存储，重启后丢失，性能最好
#   json   - JSON文件持久化存储，适合单实例部署
#   redis  - Redis存储（预留接口，尚未实现）
SESSION_STORAGE=memory

# Session 超时时间（分钟）
# 超过此时间没有活动的 Session 将被清理
SESSION_TIMEOUT=20

# Session 存储目录（仅 json 模式使用）
# 需要确保此目录存在且有写入权限
SESSION_DIR=./runtime/sessions

# Redis 连接配置（预留，仅 redis 模式使用）
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_KEY_PREFIX=vbscript:session:

# =============================================================================
# 日期时间格式配置
# =============================================================================
# 参考微软官方文档：
# https://learn.microsoft.com/zh-tw/office/vba/language/reference/user-interface-help/format-function-visual-basic-for-applications
#
# 支持的格式符：
#   yyyy = 四位年份 (2024)
#   yy   = 两位年份 (24)
#   mm   = 月份，带前导零 (01-12)
#   m    = 月份，不带前导零 (1-12)
#   dd   = 日期，带前导零 (01-31)
#   d    = 日期，不带前导零 (1-31)
#   hh   = 小时，带前导零 (00-23)
#   h    = 小时，不带前导零 (0-23)
#   nn   = 分钟，带前导零 (00-59)
#   n    = 分钟，不带前导零 (0-59)
#   ss   = 秒，带前导零 (00-59)
#   s    = 秒，不带前导零 (0-59)
#
# 注意：VBScript 标准中 m/mm 在 h/hh 后表示分钟，当前实现统一使用 n/nn
NOW_FORMAT=yyyy/mm/dd hh:nn:ss
DATE_FORMAT=yyyy/mm/dd
TIME_FORMAT=hh:nn:ss

# =============================================================================
# CreateObject 安全配置
# =============================================================================

# CreateObject 功能开关 (true/false)
# 关闭后将禁用 Server.CreateObject 方法
CREATE_OBJECT_ENABLE=true

# Server.CreateObject 白名单（逗号分隔）
# 出于安全考虑，只允许创建以下对象：
#
# 【已支持的对象】
# - Scripting.Dictionary:      字典对象，用于键值对存储
# - Scripting.FileSystemObject: 文件系统对象，用于文件和文件夹操作
# - MSXML2.XMLHTTP:             HTTP 请求对象，用于发起 HTTP 请求
#
# 【不支持的对象（将被拒绝）】
# - ADODB.Connection:           数据库连接（COM 组件，不支持）
# - ADODB.Recordset:            记录集（COM 组件，不支持）
# - 任何其他 COM/ActiveX 组件
#
# 如需添加自定义对象支持，需要修改源码中的对象工厂
CREATE_OBJECT_WHITELIST=Scripting.Dictionary,Scripting.FileSystemObject,MSXML2.XMLHTTP
